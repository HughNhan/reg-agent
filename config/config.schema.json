{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "reg-agent Configuration Schema",
  "description": "Configuration schema for reg-agent CI/CD orchestrator",
  "type": "object",
  "required": ["quads"],
  "properties": {
    "comment": {
      "type": "string",
      "description": "Optional comment describing this configuration"
    },
    "version": {
      "type": "string",
      "description": "Configuration version"
    },
    "quads": {
      "type": "object",
      "description": "QUADS resource allocation configuration",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["allocate", "import"],
          "description": "QUADS mode: allocate new resources or import existing allocation"
        },
        "api_server": {
          "type": "string",
          "minLength": 1,
          "description": "QUADS API server hostname (without https:// - ansible adds it automatically)"
        },
        "username": {
          "type": "string",
          "minLength": 1,
          "description": "QUADS username"
        },
        "password": {
          "type": "string",
          "description": "QUADS password (leave empty if using api_token)"
        },
        "api_token": {
          "type": "string",
          "description": "QUADS API token (preferred over password)"
        },
        "user_domain": {
          "type": "string",
          "description": "User email domain (e.g., redhat.com)"
        },
        "lab": {
          "type": "string",
          "enum": ["scalelab", "performancelab", "byol"],
          "description": "Lab location (byol = bring your own lab, no QUADS API needed)"
        },
        "num_hosts": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of hosts to allocate (required for mode=allocate)"
        },
        "preferred_model": {
          "type": "string",
          "minLength": 1,
          "description": "Preferred hardware model (e.g., r750, r740xd)"
        },
        "workload_name": {
          "type": "string",
          "minLength": 1,
          "description": "Workload identifier for the allocation"
        },
        "short_description": {
          "type": "string",
          "description": "Short description of the allocation purpose"
        },
        "wipe_disks": {
          "type": "string",
          "enum": ["yes", "no"],
          "description": "Whether to wipe disks on allocation (use 'yes' or 'no', not boolean true/false)"
        },
        "cloud_name": {
          "type": "string",
          "minLength": 1,
          "description": "Cloud name for import mode (e.g., cloud23)"
        }
      },
      "required": ["mode", "lab"],
      "allOf": [
        {
          "if": {
            "properties": { "lab": { "const": "byol" } },
            "required": ["lab"]
          },
          "then": {
            "properties": { "mode": { "const": "import" } },
            "required": ["mode"]
          }
        },
        {
          "if": {
            "properties": { "lab": { "enum": ["scalelab", "performancelab"] } },
            "required": ["lab"]
          },
          "then": {
            "required": ["api_server", "username"]
          }
        },
        {
          "if": {
            "properties": { "mode": { "const": "allocate" } },
            "required": ["mode"]
          },
          "then": {
            "required": ["num_hosts", "preferred_model", "workload_name"]
          }
        },
        {
          "if": {
            "allOf": [
              { "properties": { "mode": { "const": "import" } }, "required": ["mode"] },
              { "properties": { "lab": { "enum": ["scalelab", "performancelab"] } }, "required": ["lab"] }
            ]
          },
          "then": {
            "required": ["cloud_name"]
          }
        }
      ]
    },
    "jetlag": {
      "type": "object",
      "description": "Jetlag cluster deployment configuration",
      "properties": {
        "_comment_allocate": {
          "type": "string",
          "description": "For allocate mode, provide: cluster_type, worker_node_count, ocp_build, ocp_version, network_stack, pull_secret_path, bmc_password"
        },
        "_comment_import": {
          "type": "string",
          "description": "For import mode, provide: bastion_host, kubeconfig_path (cluster_type not needed, Regulus will discover)"
        },
        "cluster_type": {
          "type": "string",
          "enum": ["mno", "sno", "bm"],
          "description": "Cluster type: mno (multi-node), sno (single-node), or bm (bare metal) - only required for allocate mode"
        },
        "worker_node_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of worker nodes (for MNO in allocate mode)"
        },
        "ocp_build": {
          "type": "string",
          "enum": ["ga", "nightly", "rc"],
          "description": "OpenShift build type (for allocate mode)"
        },
        "ocp_version": {
          "type": "string",
          "description": "OpenShift version (e.g., latest-4.20, 4.18.1) - for allocate mode"
        },
        "network_stack": {
          "type": "string",
          "enum": ["ipv4", "ipv6", "dual"],
          "description": "Network stack configuration (for allocate mode)"
        },
        "ipv6_mode": {
          "type": "string",
          "description": "IPv6 configuration mode (when using ipv6 network_stack)"
        },
        "pull_secret_path": {
          "type": "string",
          "description": "Path to OpenShift pull secret file (for allocate mode)"
        },
        "bmc_password": {
          "type": "string",
          "description": "BMC/IPMI password for bare metal hosts (for allocate mode)"
        },
        "bastion_host": {
          "type": "string",
          "minLength": 1,
          "description": "Bastion host FQDN or IP (required for import mode)"
        },
        "kubeconfig_path": {
          "type": "string",
          "minLength": 1,
          "description": "Path to kubeconfig file on bastion (required for import mode)"
        }
      },
      "required": []
    },
    "crucible": {
      "type": "object",
      "description": "Crucible benchmark framework configuration",
      "properties": {
        "git_repo": {
          "type": "string",
          "description": "Crucible git repository URL"
        },
        "git_branch": {
          "type": "string",
          "description": "Crucible git branch"
        },
        "install_script": {
          "type": "string",
          "description": "Crucible installation script name"
        }
      }
    },
    "crucible_controller": {
      "type": "object",
      "description": "Crucible controller host configuration",
      "properties": {
        "target": {
          "type": "string",
          "enum": ["bastion", "other"],
          "description": "Where to install Crucible: bastion (from Jetlag) or other host"
        },
        "user": {
          "type": "string",
          "description": "SSH user for controller host"
        },
        "password": {
          "type": "string",
          "description": "SSH password for controller host (optional if using key-based auth)"
        },
        "other_host": {
          "type": "string",
          "minLength": 1,
          "description": "Custom controller hostname (required if target=other)"
        }
      },
      "required": ["target"],
      "if": {
        "properties": { "target": { "const": "other" } }
      },
      "then": {
        "required": ["other_host"]
      }
    },
    "regulus": {
      "type": "object",
      "description": "Regulus performance testing configuration",
      "properties": {
        "install_subdir": {
          "type": "string",
          "description": "Optional subdirectory under /root for Regulus installation"
        },
        "bastion_ssh_user": {
          "type": "string",
          "description": "SSH user for bastion host"
        },
        "jobs": {
          "type": "string",
          "pattern": "^(\\./[^ ]+( \\./[^ ]+)*)?$",
          "description": "Space-separated test job paths (e.g., './1_GROUP/NO-PAO/4IP/INTER-NODE/TCP/2-POD' or './1_GROUP/NO-PAO/4IP ./2_GROUP/PAO/6IP')"
        },
        "duration": {
          "type": "integer",
          "minimum": 1,
          "description": "Test duration in seconds"
        },
        "tag": {
          "type": "string",
          "description": "Test identifier tag"
        },
        "num_samples": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of test samples to run"
        },
        "test_suite": {
          "type": "string",
          "description": "Optional test suite name"
        }
      }
    },
    "lab": {
      "type": "object",
      "description": "Lab environment SSH configuration (optional, has defaults)",
      "properties": {
        "ssh_username": {
          "type": "string",
          "default": "root",
          "description": "Default SSH username for lab machines (defaults to 'root' if omitted)"
        },
        "ssh_password": {
          "type": "string",
          "description": "Default SSH password for lab machines (optional, SSH keys preferred)"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "quads": {
            "properties": { "mode": { "const": "allocate" } },
            "required": ["mode"]
          }
        },
        "required": ["quads"]
      },
      "then": {
        "properties": {
          "jetlag": {
            "required": ["cluster_type", "ocp_build", "ocp_version", "network_stack"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "quads": {
            "properties": { "mode": { "const": "import" } },
            "required": ["mode"]
          }
        },
        "required": ["quads"]
      },
      "then": {
        "properties": {
          "jetlag": {
            "required": ["bastion_host", "kubeconfig_path"]
          }
        }
      }
    }
  ]
}
