{
  "comment": "Sample configuration for reg-agent automated deployment",
  "version": "1.0",

  "quads": {
    "api_server": "quads2.rdu2.scalelab.redhat.com",
    "username": "your-username",
    "password": "your-password",
    "api_token": "",
    "lab": "scalelab",
    "num_hosts": 6,
    "preferred_model": "r650,r750",
    "workload_name": "reg-agent-testing",
    "short_description": "OpenShift Performance Testing",
    "wipe_disks": "no"
  },

  "lab": {
    "ssh_password": "your-lab-password",
    "ssh_username": "root",
    "bastion_ssh_user": "root",
    "_comment_bastion_ssh_user": "SSH username to access bastion host. Options: 'root' (lab), 'kni' (Jetlag/IPI), 'core' (CoreOS)"
  },

  "jetlag": {
    "cluster_type": "mno",
    "ocp_version": "latest-4.20",
    "ocp_build": "ga",
    "network_stack": "ipv4",
    "worker_node_count": 3,
    "pull_secret_path": "/root/pull-secret.txt"
  },

  "crucible_controller": {
    "target": "bastion",
    "_comment_target": "Options: 'bastion' (cluster bastion from Jetlag) or 'other' (specify custom host)",
    "other_host": "",
    "_comment_other_host": "Required if target='other'. Host where Crucible & Regulus will be installed",
    "user": "root",
    "_comment_user": "SSH username for controller host"
  },

  "crucible": {
    "git_repo": "",
    "_comment_git_repo": "Confidential: Git repository URL (e.g., https://gitlab.cee.redhat.com/...)",
    "git_branch": "master",
    "install_script": "rh-install-crucible.sh",
    "_comment_install_script": "Installation script name in the cloned repository"
  },

  "regulus": {
    "install_subdir": "",
    "_comment_install_subdir": "Optional subdirectory under /root. Final path: /root/<subdir>/cpt-regulus-<datetime>",
    "test_suite": "standard",
    "duration": "1h"
  }
}
